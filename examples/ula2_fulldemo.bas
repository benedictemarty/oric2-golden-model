10 REM =============================
20 REM  ULA2 FULL DEMO - PHOSPHORIC
30 REM  COLOR RAM AT $B000 (45056)
40 REM =============================
50 CR=45056:SC=48768
60 REM ULA2 CLS: reset Color RAM then CLS
70 POKE CR+1119,255:CLS
70 REM --- TITRE ARC-EN-CIEL ---
80 T$="PHOSPHORIC ULA2 DEMO"
90 FOR I=1 TO LEN(T$)
100 C=I-INT(I/7)*7+1
110 POKE CR+40+10+I,C
120 NEXT I
130 PRINT
140 PRINT"           ";T$
150 REM --- BANDES COULEUR PAPER ---
160 PRINT
170 PRINT
180 FOR C=0 TO 7
190 FOR X=0 TO 4
200 POKE CR+4*40+C*5+X,7+C*8
210 POKE SC+4*40+C*5+X,32
220 NEXT X
230 NEXT C
240 REM --- BANDES COULEUR INK ---
250 PRINT
260 FOR C=0 TO 7
270 FOR X=0 TO 4
280 POKE CR+6*40+C*5+X,C+0*8
290 POKE SC+6*40+C*5+X,160
300 NEXT X
310 NEXT C
320 REM --- DAMIER ---
330 PRINT
340 PRINT
350 PRINT
360 FOR Y=0 TO 3
370 FOR X=0 TO 39
380 C1=X-INT(X/8)*8
390 C2=7-C1
400 IF (X+Y)-INT((X+Y)/2)*2=0 THEN POKE CR+(10+Y)*40+X,C1+C2*8
410 IF (X+Y)-INT((X+Y)/2)*2=1 THEN POKE CR+(10+Y)*40+X,C2+C1*8
420 POKE SC+(10+Y)*40+X,160
430 NEXT X
440 NEXT Y
450 REM --- TEXTE COLORE ---
460 PRINT
470 PRINT
480 PRINT
490 PRINT
500 PRINT
510 A$="CHAQUE CELLULE A SA COULEUR"
520 PRINT"       ";A$
530 FOR I=1 TO LEN(A$)
540 C=I-INT(I/7)*7+1
550 POKE CR+17*40+7+I,C
560 NEXT I
570 REM --- INVERSE DEMO ---
580 PRINT
590 B$="TEXTE INVERSE SANS ATTRIBUT"
600 PRINT"       ";B$
610 FOR I=1 TO LEN(B$)
620 C=I-INT(I/7)*7+1
630 POKE CR+19*40+7+I,C+0*8+128
640 NEXT I
650 REM --- ANIMATION ---
660 PRINT
670 PRINT
680 PRINT"   ANIMATION COULEUR (ESC=QUIT)"
690 FOR F=0 TO 255
700 FOR X=0 TO 39
710 C=(X+F)-INT((X+F)/7)*7+1
720 POKE CR+22*40+X,C+0*8
730 POKE SC+22*40+X,160
740 NEXT X
750 K$=KEY$
760 IF K$="" THEN GOTO 790
770 IF ASC(K$)=27 THEN END
780 REM
790 NEXT F
800 GOTO 690
