10 REM HIRES GRAPHICS DEMO FOR ORIC-1
20 REM DEMONSTRATES 240x200 GRAPHICS
30 HIRES
40 REM DRAW A BORDER
50 FOR X=0 TO 239
60 CURSET X,0,1
70 CURSET X,199,1
80 NEXT X
90 FOR Y=0 TO 199
100 CURSET 0,Y,1
110 CURSET 239,Y,1
120 NEXT Y
130 REM DRAW DIAGONAL LINES
140 FOR I=0 TO 199 STEP 10
150 CURSET 0,0,3
160 DRAW 239,I,1
170 NEXT I
180 REM DRAW A CIRCLE PATTERN
190 FOR A=0 TO 360 STEP 15
200 X1=120+80*COS(A*3.14159/180)
210 Y1=100+80*SIN(A*3.14159/180)
220 CURSET 120,100,3
230 DRAW X1-120,Y1-100,1
240 NEXT A
250 REM WAIT FOR KEY
260 GET A$
270 TEXT
280 END
