10 REM ACIA 6551 SERIAL TEST
20 CLS
30 PRINT"*** ACIA 6551 TEST ***"
40 PRINT
50 DA=796:ST=797:CM=798:CT=799
60 POKE ST,0
70 S=PEEK(ST)
80 T=(S AND 16)/16
90 PRINT"TEST 1 RESET TDRE=";T
100 POKE CT,30
110 V=PEEK(CT)
120 PRINT"TEST 2 CTRL REG=";V
130 POKE CM,3
140 V=PEEK(CM)
150 PRINT"TEST 3 CMD REG=";V
160 POKE ST,0
170 POKE CT,31
180 POKE CM,3
190 POKE DA,66
200 FOR W=1 TO 2000
210 NEXT W
220 S=PEEK(ST)
230 IF (S AND 8)=0 THEN PRINT"TEST 4 NO RX":GOTO 260
240 V=PEEK(DA)
250 PRINT"TEST 4 LOOPBACK=";V
260 POKE ST,0
270 POKE CT,31
280 POKE CM,3
290 OK=0
300 FOR I=0 TO 9
310 POKE DA,65+I
320 FOR W=1 TO 500
330 NEXT W
340 S=PEEK(ST)
350 IF (S AND 8)=0 THEN GOTO 390
360 V=PEEK(DA)
370 IF V=65+I THEN OK=OK+1
380 REM
390 NEXT I
400 PRINT"TEST 5 MULTI=";OK;"/10"
410 PRINT
420 PRINT"ALL TESTS DONE"
430 PRINT"PRESS T FOR TERMINAL"
440 GET A$
450 IF A$<>"T" THEN END
460 CLS
470 PRINT"TERMINAL (ESC=QUIT)"
480 PRINT
490 POKE ST,0
500 POKE CT,31
510 POKE CM,3
520 S=PEEK(ST)
530 IF (S AND 8)=0 THEN GOTO 570
540 C=PEEK(DA)
550 IF C=13 THEN PRINT
560 IF C>31 AND C<127 THEN PRINT CHR$(C);
570 K$=KEY$
580 IF K$="" THEN GOTO 520
590 IF ASC(K$)=27 THEN END
600 POKE DA,ASC(K$)
610 GOTO 520
