10 REM KEY TESTER - AFFICHE TOUTES LES TOUCHES
20 REM Y COMPRIS LES INVISIBLES (FLECHES, ESC, DEL)
30 CLS
40 PRINT "*** ORIC KEY TESTER ***"
50 PRINT
60 PRINT "APPUYEZ SUR UNE TOUCHE..."
70 PRINT "CTRL+C POUR QUITTER"
80 PRINT
90 PRINT "DEC  HEX  TOUCHE"
100 PRINT "---- ---- ------"
110 REM ATTENTE TOUCHE VIA GET
120 GET A$
130 K=ASC(A$)
140 REM AFFICHE CODE DECIMAL
150 IF K<100 THEN PRINT " ";
160 IF K<10 THEN PRINT " ";
170 PRINT K;"  ";
180 REM AFFICHE CODE HEX
190 H=INT(K/16)
200 L=K-H*16
210 IF H<10 THEN PRINT CHR$(48+H);
220 IF H>9 THEN PRINT CHR$(55+H);
230 IF L<10 THEN PRINT CHR$(48+L);
240 IF L>9 THEN PRINT CHR$(55+L);
250 PRINT "  ";
260 REM NOM DES TOUCHES SPECIALES
270 IF K=8 THEN PRINT "LEFT <-"
280 IF K=9 THEN PRINT "RIGHT ->"
290 IF K=10 THEN PRINT "DOWN v"
300 IF K=11 THEN PRINT "UP ^"
310 IF K=12 THEN PRINT "FUNCT"
320 IF K=13 THEN PRINT "RETURN"
330 IF K=27 THEN PRINT "ESC"
340 IF K=32 THEN PRINT "SPACE"
350 IF K>32 AND K<127 THEN PRINT CHR$(K)
360 IF K<8 THEN PRINT "CTRL+";CHR$(K+64)
370 IF K>13 AND K<27 THEN PRINT "CTRL+";CHR$(K+64)
380 IF K>27 AND K<32 THEN PRINT "CTRL+";CHR$(K+64)
390 IF K=127 THEN PRINT "DEL 7F"
400 GOTO 120
